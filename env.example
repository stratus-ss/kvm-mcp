# ==============================================================================
# KVM MCP Server Environment Configuration
# ==============================================================================
# Copy this file to .env and customize for your environment
# This MCP server manages KVM/libvirt virtual machines across one or more hosts

# ==============================================================================
# KVM Host Configuration (Single Host Mode)
# ==============================================================================
# Primary KVM host connection details - leave empty to use local libvirt
KVM_HOST=dl380
KVM_HOST_USER=root
KVM_HOST_SSH_KEY=~/.ssh/id_rsa

# Alternative: Multi-host configuration via YAML file
# KVM_HOSTS_FILE=hosts.yaml

# ==============================================================================
# Security & Path Restrictions
# ==============================================================================
# Allowed paths for VM disk storage (comma-separated)
ALLOWED_DISK_PATHS=/var/lib/libvirt/images

# Allowed paths for ISO files (comma-separated) 
ALLOWED_ISO_PATHS=/var/lib/libvirt/images,/home,/var/lib/libvirt/boot

# Disable sudo requirement (useful for containerized deployments)
KVM_DISABLE_SUDO=false

# ==============================================================================
# Logging Configuration
# ==============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=json

# ==============================================================================
# MCP Audit Logging
# ==============================================================================
# Directory for structured audit logs (JSONL format)
# Tracks all tool calls and resource reads for security auditing
MCP_AUDIT_LOG_DIR=/var/log/kvm-mcp

# ==============================================================================
# Development/Testing Options
# ==============================================================================
# Set to true to run in development mode (additional debugging)
# DEV_MODE=false

# Override default libvirt connection timeout (seconds)
# LIBVIRT_TIMEOUT=30

# ==============================================================================
# Example Multi-Host YAML Configuration (hosts.yaml)
# ==============================================================================
# If using KVM_HOSTS_FILE instead of single host config above:
#
# default_host: production
# hosts:
#   - name: production
#     uri: qemu+ssh://root@prod-kvm.local/system
#     ssh_user: root
#     ssh_key: ~/.ssh/prod_rsa
#     allowed_disk_paths: /var/lib/libvirt/images,/storage/vms
#     allowed_iso_paths: /var/lib/libvirt/images,/storage/iso
#   - name: development  
#     uri: qemu+ssh://admin@dev-kvm.local/system
#     ssh_user: admin
#     ssh_key: ~/.ssh/dev_rsa
#     allowed_disk_paths: /var/lib/libvirt/images
#     allowed_iso_paths: /var/lib/libvirt/images,/home/admin/iso